# Demo mode is deterministic, offline, and requires no API key.
SUMMARY_MODE=demo

# Live OpenRouter mode (set SUMMARY_MODE=openrouter and replace the key).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=1

# Pipeline and storage limits.
MAX_CHUNK_SIZE=8000
MAX_UPLOAD_BYTES=52428800
DATABASE_URL=sqlite:///./data/document-summary.sqlite3

# The Streamlit UI uses the host URL locally and the container URL in Compose.
BACKEND_API_URL=http://127.0.0.1:8000
CONTAINER_BACKEND_API_URL=http://api:8000

